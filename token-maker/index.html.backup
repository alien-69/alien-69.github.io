      <div class="col">
        <h1 class="display-5 fw-bold lh-1 mb-3 mt-2">
          Create your BEP20 token
        </h1>
        <p class="lead">Simple. No coding required.</p>

        <label class="col-sm-3 col-form-lable">Token type </label>
        <div class="col-sm">
          <select class="form-select token_type text-white" aria-label="Select token type">
            <option value="basic" selected>Standard</option>
            <option value="safemoon">Safemoon (Deflationary)</option>
            <option value="liquiditygenerator">Liquidity Generator</option>
            <option value="frictionlessyield">Frictionless Yield</option>
            <option value="marketingtax">Marketing Tax</option>
            <option value="smarttax">Smart Tax</option>
            <option value="rewardtoken">Reward Token</option>
            <option value="rewardtoken2">Reward Pro</option>
            <option value="starship">Starship</option>
            <option value="customizedToken">Customized Token</option>
          </select>
          <p class="hint">Select token type you want to create.</p>
          <div class="col">
            <span class="badge bg-info" id="tag_popular">Popular</span>
            <span class="badge bg-danger" id="tag_hot">🔥Hot</span>
            <span class="badge bg-success" id="tag_new">New</span>
          </div>

        </div>

        <div id="token_container"></div>

        <script>
          var default_token_type = "basic"
          $('.token_type option[value=' + default_token_type + ']').prop('selected', 'selected');
          $("#token_container").load("static/views/" + default_token_type + ".html")

          $(".token_type").on("change", () => {

            var token_type = $(".token_type").val()

            $("#token_container").load("static/views/" + token_type + ".html")

            if (token_type == "customizedToken") {
              $(".actionGroup").hide()
            } else {
              $(".actionGroup").show()
            }
          })

          function changeTokenType(token_type) {
            $('.token_type option[value=' + token_type + ']').prop('selected', 'selected');
            $("#token_container").load("static/views/" + token_type + ".html")
          }

          $("#tag_popular").on("click", () => {
            changeTokenType('basic')
          })

          $("#tag_hot").on("click", () => {
            changeTokenType('marketingtax')
          })

          $("#tag_new").on("click", () => {
            changeTokenType('starship')
          })
        </script>

