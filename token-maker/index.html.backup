          <script>
            $("#moonshots").on("click", function () {
              $(".actionGroup").css("display", "none");
              if ($(".moonshotOffers").css("display") == "none") {
                $(".toggle").removeClass("fa-angles-down");
                $(".toggle").addClass("fa-angles-up");

                $(".moonshotOffers").css("display", "block");

              } else {
                closeMoonshots();
              }
            })

            function closeMoonshots() {
              $(".toggle").addClass("fa-angles-down");
              $(".toggle").removeClass("fa-angles-up");
              $(".moonshotOffers").css("display", "none");
            }
          </script>

